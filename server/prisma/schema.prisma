generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Plan {
  FREE
  PRO
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  name      String?
  avatarUrl String?

  passwordHash String?

  planExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  endpoints Endpoint[]
  sessions  Session[]

  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────────
// SESSION (for web dashboard login)
// ─────────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([tokenHash, expiresAt])
  @@map("sessions")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  sessionId String
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([tokenHash, expiresAt])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// ENDPOINT
// User creates an endpoint — gets a unique URL
// e.g. webhookmonitor.io/in/k7x9mQpLnR4
// ─────────────────────────────────────────────

model Endpoint {
  id          String  @id @default(cuid()) // used in URL: /in/:id
  userId      String
  name        String // "Stripe Production"
  description String?

  listenUrl  String
  forwardUrl String
  slug       String @unique

  isActive Boolean @default(true)

  totalReceived  Int       @default(0)
  totalDelivered Int       @default(0)
  totalFailed    Int       @default(0)
  lastReceivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests WebhookRequest[]

  @@unique([userId, name])
  @@index([userId, id])
  @@index([slug])
  @@index([isActive])
  @@map("endpoints")
}

// ─────────────────────────────────────────────
// WEBHOOK REQUEST
// Every incoming webhook — stored forever (or until retention limit)
// ─────────────────────────────────────────────

model WebhookRequest {
  id         String @id @default(cuid())
  endpointId String

  headers Json?
  body    Json?

  sourceIp String?

  responseStatus Int?
  responseTimeMs Int?

  deliveryStatus DeliveryStatus @default(PENDING)

  receivedAt DateTime @default(now())

  endpoint Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([receivedAt(sort: Desc)])
}
